STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── FEATURE TOGGLES ─────────────────────────────────────

# ============ GUARDIAN ROUTES ============
# Table name (override if needed, default: guardian_routes_app)
GUARDIAN_ROUTES_TABLE=guardian_routes_app

# ============ NOTES ============
# 1. NEVER commit this file to version control
# 2. For production, use strong JWT_SECRET (32+ characters)
# 3. Set NODE_ENV=production in production
# 4. SMS/Voice optional but recommended for full features
# 5. Keep private.key file secure and in .gitignore
