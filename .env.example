# ===================================
# USafe Backend - Environment Configuration
# ===================================

# ============ DATABASE (REQUIRED) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_database_password
DB_NAME=usafe_db
DB_CONNECTION_TIMEOUT_MS=10000
DB_SSL=true

# ============ SUPABASE (REQUIRED) ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ============ AUTHENTICATION (REQUIRED) ============
JWT_SECRET=your_very_long_and_secure_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ============ SMS PROVIDER (OPTIONAL) ============
# QuickSend SMS service for alerts
QUICKSEND_EMAIL=your_quicksend_email@example.com
QUICKSEND_API_KEY=your_quicksend_api_key
SOS_SENDER_ID=USafe

# ============ VOICE CALLS (OPTIONAL) ============
# Vonage (formerly Nexmo) for emergency voice calls
VONAGE_APPLICATION_ID=your_vonage_app_id
VONAGE_PRIVATE_KEY=./private.key
VONAGE_FROM_NUMBER=+1234567890
SOS_CALL_TO=+default_emergency_number
SOS_CALL_TEXT=This is an emergency alert from USafe

# ============ PAYMENTS (OPTIONAL) ============
# Stripe for subscription and payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============ GOOGLE OAUTH (OPTIONAL) ============
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development
API_VERSION=1.0.0

# ============ FEATURE TOGGLES ============
DISABLE_CALLS=false
DISABLE_SMS=false
DISABLE_BULK_SMS=false

# ============ SAFETY SCORING ============
PYTHON_EXECUTABLE=python
SAFETY_SCORE_TIMEOUT_MS=8000

# ============ GUARDIAN ROUTES ============
# Table name (override if needed, default: guardian_routes_app)
GUARDIAN_ROUTES_TABLE=guardian_routes_app

# ============ NOTES ============
# 1. NEVER commit this file to version control
# 2. For production, use strong JWT_SECRET (32+ characters)
# 3. Set NODE_ENV=production in production
# 4. SMS/Voice optional but recommended for full features
# 5. Keep private.key file secure and in .gitignore
