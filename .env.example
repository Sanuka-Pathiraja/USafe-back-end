# ============================================================
#  SafeZone — Environment Variables
#  Copy this file to .env and fill in your own values.
#  Never commit .env to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=5000

# development | production
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
# Full PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (required for Google login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ─── Vonage (Voice Calls) ─────────────────────────────────────
# Required for emergency voice calls
VONAGE_APPLICATION_ID=your_vonage_application_id
VONAGE_FROM_NUMBER=your_vonage_number         # e.g. 94711234567
VONAGE_PRIVATE_KEY=./private.key              # path to Vonage private key file

# ─── Notify.lk (SMS — Sri Lanka) ─────────────────────────────
# Required for emergency SMS alerts
NOTIFYLK_USER_ID=your_notifylk_user_id
NOTIFYLK_API_KEY=your_notifylk_api_key
NOTIFYLK_SENDER_ID=NotifyDEMO
NOTIFYLK_BASE_URL=https://app.notify.lk/api/v1

# Alternate env names also accepted by some modules
NOTIFY_USER_ID=your_notifylk_user_id
NOTIFY_API_KEY=your_notifylk_api_key
NOTIFY_SENDER_ID=NotifyDEMO

# Set to "true" to force Unicode mode for all Notify.lk SMS
NOTIFY_SMS_UNICODE=false

# ─── QuickSend (SMS / Bulk SMS) ───────────────────────────────
# Required for QuickSend-based bulk SMS
QUICKSEND_EMAIL=your_quicksend_email
QUICKSEND_API_KEY=your_quicksend_api_key

# ─── Twilio (Demo/Fallback Calls) ─────────────────────────────
# Optional — only used by the demo call module
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ─── Firebase Cloud Messaging (Push Notifications) ───────────
# Required for in-app push notifications
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n characters, not real newlines
FIREBASE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# ─── Mapbox (Safe Route) ──────────────────────────────────────
# Required for safe route calculation
MAPBOX_TOKEN=pk.your_mapbox_public_access_token

# ─── Google Maps / Places / OpenWeather (Safety Score) ───────
# Used for live safety scoring on community reports
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key
OPENWEATHER_API_KEY=your_openweather_api_key

# Crime data APIs (fallback chain for safety scoring)
CRIME_API_KEY=your_crime_api_key
API_NINJAS_API_KEY=your_api_ninjas_key

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── PayHere (LKR Payments) ──────────────────────────────────
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret

# ─── Emergency / SOS Configuration ───────────────────────────
# Default call/SMS targets when no specific contact is set
SOS_CALL_TO=94711234567           # number to call for SOS
SOS_SMS_TO=94711234567            # number to SMS for SOS
SOS_BULK_TO=94711234567,94712345678  # comma-separated list
SOS_SENDER_ID=USafe
SOS_MESSAGE=USafe SOS Alert - Please respond immediately
SOS_CALL_TEXT=This is an automated emergency call from USafe. Please respond.
SOS_CANCEL_MESSAGE=User has cancelled the emergency process.

# Emergency services number (default: 119)
EMERGENCY_SERVICE_NUMBER=119

# ─── URL Configuration ───────────────────────────────────────
# Base URLs used for webhooks and tracking links
PUBLIC_BASE_URL=https://your-backend-domain.com
WEBHOOK_BASE_URL=https://your-backend-domain.com
TRIP_TRACKING_BASE_URL=https://your-frontend-domain.com/track
WEB_DASHBOARD_BASE_URL=https://your-frontend-domain.com

# ─── Feature Toggles ─────────────────────────────────────────
# Set to "true" to disable features without removing code
DISABLE_CALLS=false
DISABLE_SMS=false
DISABLE_BULK_SMS=false

# Dev-only — allows demo call IDs when Vonage is unavailable
ALLOW_DEMO_CALL_FALLBACK=false

# Dev-only — allows specifying a custom call target (bypasses production guard)
ALLOW_DEV_CUSTOM_CALL_TARGET=false

# ─── Push Notification Tuning ────────────────────────────────
# Minutes between low-safety-score notifications for the same user (default: 20)
LOW_SAFETY_NOTIFICATION_COOLDOWN_MINUTES=20
