# ===================================
# USafe Backend - Environment Configuration
# ===================================

# ============ DATABASE (REQUIRED) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_database_password
DB_NAME=usafe_db
DB_CONNECTION_TIMEOUT_MS=10000
DB_SSL=true

# ============ SUPABASE (REQUIRED) ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ============ AUTHENTICATION (REQUIRED) ============
JWT_SECRET=your_very_long_and_secure_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ============ SMS PROVIDER (OPTIONAL) ============
# QuickSend SMS service for alerts
QUICKSEND_EMAIL=your_quicksend_email@example.com
QUICKSEND_API_KEY=your_quicksend_api_key
SOS_SENDER_ID=USafe

# ============ VOICE CALLS (OPTIONAL) ============
# Vonage (formerly Nexmo) for emergency voice calls
VONAGE_APPLICATION_ID=your_vonage_app_id
VONAGE_PRIVATE_KEY=./private.key
VONAGE_FROM_NUMBER=+1234567890
SOS_CALL_TO=+default_emergency_number
SOS_CALL_TEXT=This is an emergency alert from USafe

# ============ PAYMENTS (OPTIONAL) ============
# Stripe for subscription and payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============ GOOGLE OAUTH (OPTIONAL) ============
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development
API_VERSION=1.0.0

# ============ FEATURE TOGGLES ============
=======
# ============================================================
#  SafeZone — Environment Variables
#  Copy this file to .env and fill in your own values.
#  Never commit .env to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=5000

# development | production
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
# Full PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_ANON_KEY=your_supabase_anon_or_service_key  # same value as SUPABASE_KEY (used by utils/supabaseClient.js)

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (required for Google login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ─── Vonage (Voice Calls) ─────────────────────────────────────
# Required for emergency voice calls
VONAGE_APPLICATION_ID=your_vonage_application_id
VONAGE_FROM_NUMBER=your_vonage_number         # e.g. 94711234567
VONAGE_PRIVATE_KEY=./private.key              # path to Vonage private key file

# ─── Notify.lk (SMS — Sri Lanka) ─────────────────────────────
# Required for emergency SMS alerts
NOTIFYLK_USER_ID=your_notifylk_user_id
NOTIFYLK_API_KEY=your_notifylk_api_key
