# Dev-only — allows demo call IDs when Vonage is unavailable
ALLOW_DEMO_CALL_FALLBACK=false

# Dev-only — allows specifying a custom call target (bypasses production guard)
ALLOW_DEV_CUSTOM_CALL_TARGET=false

# ─── Push Notification Tuning ────────────────────────────────
# Minutes between low-safety-score notifications for the same user (default: 20)
LOW_SAFETY_NOTIFICATION_COOLDOWN_MINUTES=20
